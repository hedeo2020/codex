generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  HR_ADMIN
  EMPLOYEE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EnrollmentStatus {
  NOT_ENROLLED
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
  DELETED
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
  BREAK_START
  BREAK_END
}

enum VerificationMethod {
  FACE
  PIN
  ADMIN_ASSISTED
  MANUAL_CORRECTION
}

enum VerificationStatus {
  SUCCESS
  FAILED
  PENDING_REVIEW
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Role {
  id String @id @default(cuid())
  name RoleName @unique
  description String?
  permissions Json
  users User[]
}

model User {
  id String @id @default(cuid())
  employeeId String @unique @map("employee_id")
  firstName String @map("first_name")
  lastName String @map("last_name")
  email String @unique
  personalEmail String? @map("personal_email")
  phone String?
  passwordHash String @map("password_hash")
  pinHash String? @map("pin_hash")
  roleId String @map("role_id")
  role Role @relation(fields: [roleId], references: [id])
  departmentId String? @map("department_id")
  department Department? @relation(fields: [departmentId], references: [id])
  managerId String? @map("manager_id")
  manager User? @relation("ManagerReports", fields: [managerId], references: [id])
  reports User[] @relation("ManagerReports")
  shiftId String? @map("shift_id")
  shift Shift? @relation(fields: [shiftId], references: [id])
  locationId String? @map("location_id")
  location Location? @relation(fields: [locationId], references: [id])
  jobTitle String? @map("job_title")
  mobile String?
  emergencyContact Json? @map("emergency_contact")
  preferredAttendanceMethod VerificationMethod @default(FACE) @map("preferred_attendance_method")
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  dateJoined DateTime @default(now()) @map("date_joined")
  profilePhotoUrl String? @map("profile_photo_url")
  failedLoginAttempts Int @default(0) @map("failed_login_attempts")
  lockedUntil DateTime? @map("locked_until")
  attendanceRecords AttendanceRecord[]
  correctionRequests AttendanceCorrectionRequest[] @relation("Requester")
  reviewedCorrections AttendanceCorrectionRequest[] @relation("CorrectionReviewer")
  biometricProfile BiometricProfile?
  notifications Notification[]
  privacyRequests PrivacyRequest[] @relation("PrivacyRequester")
  processedPrivacyRequests PrivacyRequest[] @relation("PrivacyProcessor")
  sessions Session[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  @@map("users")
}

model Department {
  id String @id @default(cuid())
  name String @unique
  code String @unique
  managerId String? @map("manager_id")
  description String?
  isActive Boolean @default(true) @map("is_active")
  users User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("departments")
}

model Location {
  id String @id @default(cuid())
  name String @unique
  address String
  latitude Decimal?
  longitude Decimal?
  geofenceRadius Int? @map("geofence_radius")
  timezone String @default("Asia/Singapore")
  isActive Boolean @default(true) @map("is_active")
  users User[]
  shifts Shift[]
  attendanceRecords AttendanceRecord[]
  devices Device[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("locations")
}

model Shift {
  id String @id @default(cuid())
  name String @unique
  startTime String @map("start_time")
  endTime String @map("end_time")
  breakMinutes Int @default(60) @map("break_minutes")
  graceMinutes Int @default(10) @map("grace_minutes")
  earlyCheckoutMinutes Int @default(0) @map("early_checkout_minutes")
  workDays Int[] @map("work_days")
  locationId String? @map("location_id")
  location Location? @relation(fields: [locationId], references: [id])
  isActive Boolean @default(true) @map("is_active")
  users User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("shifts")
}

model BiometricProfile {
  id String @id @default(cuid())
  userId String @unique @map("user_id")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedEmbedding Bytes? @map("encrypted_embedding")
  encryptionIv Bytes? @map("encryption_iv")
  authTag Bytes? @map("auth_tag")
  embeddingVersion String @default("v1") @map("embedding_version")
  enrollmentStatus EnrollmentStatus @default(NOT_ENROLLED) @map("enrollment_status")
  consentStatus Boolean @default(false) @map("consent_status")
  consentAt DateTime? @map("consent_at")
  consentDocumentVersion String? @map("consent_document_version")
  enrolledAt DateTime? @map("enrolled_at")
  lastVerifiedAt DateTime? @map("last_verified_at")
  expiresAt DateTime? @map("expires_at")
  deletedAt DateTime? @map("deleted_at")
  deletionReason String? @map("deletion_reason")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("biometric_profiles")
}

model AttendanceRecord {
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])
  attendanceType AttendanceType @map("attendance_type")
  eventTime DateTime @default(now()) @map("event_time")
  timezone String
  verificationMethod VerificationMethod @map("verification_method")
  verificationStatus VerificationStatus @map("verification_status")
  confidenceScore Decimal? @map("confidence_score")
  locationId String? @map("location_id")
  location Location? @relation(fields: [locationId], references: [id])
  deviceId String? @map("device_id")
  ipAddress String? @map("ip_address")
  notes String?
  isFlagged Boolean @default(false) @map("is_flagged")
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")
  corrections AttendanceCorrectionRequest[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([userId, eventTime])
  @@map("attendance_records")
}

model AttendanceCorrectionRequest {
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation("Requester", fields: [userId], references: [id])
  attendanceRecordId String? @map("attendance_record_id")
  attendanceRecord AttendanceRecord? @relation(fields: [attendanceRecordId], references: [id])
  requestedChange Json @map("requested_change")
  reason String
  attachmentUrl String? @map("attachment_url")
  status RequestStatus @default(PENDING)
  reviewedBy String? @map("reviewed_by")
  reviewer User? @relation("CorrectionReviewer", fields: [reviewedBy], references: [id])
  reviewedAt DateTime? @map("reviewed_at")
  reviewerNotes String? @map("reviewer_notes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("attendance_correction_requests")
}

model Device {
  id String @id @default(cuid())
  name String
  deviceType String @map("device_type")
  locationId String? @map("location_id")
  location Location? @relation(fields: [locationId], references: [id])
  deviceIdentifier String @unique @map("device_identifier")
  status String @default("ACTIVE")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("devices")
}

model AuditLog {
  id String @id @default(cuid())
  actorUserId String? @map("actor_user_id")
  action String
  entityType String @map("entity_type")
  entityId String? @map("entity_id")
  oldValues Json? @map("old_values")
  newValues Json? @map("new_values")
  reason String?
  ipAddress String? @map("ip_address")
  deviceInfo String? @map("device_info")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  title String
  message String
  type String
  isRead Boolean @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("notifications")
}

model PrivacyRequest {
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation("PrivacyRequester", fields: [userId], references: [id])
  requestType String @map("request_type")
  status RequestStatus @default(PENDING)
  reason String
  processedBy String? @map("processed_by")
  processor User? @relation("PrivacyProcessor", fields: [processedBy], references: [id])
  processedAt DateTime? @map("processed_at")
  notes String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("privacy_requests")
}

model Session {
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  revokedAt DateTime? @map("revoked_at")
  @@map("sessions")
}

model SystemSetting {
  key String @id
  value Json
  updatedBy String? @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("system_settings")
}
